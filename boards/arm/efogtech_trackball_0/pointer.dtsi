/*
 * Trackball peripheral pointer configuration.
 * Full processing chain runs on peripheral, XYZ compressed before BLE.
 * Dongle only decompresses.
 */

#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/p2sm.h>
#include <dt-bindings/zmk/paw3395-modes.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <input/processors/xyz.dtsi>

/* Base mixer node */
/ {
	zip_2s_mixer: zip_2s_mixer {
		compatible = "zmk,pointer-2s-mixer";
		#input-processor-cells = <1>;
		sync-report-ms = <1>;
		sync-scroll-report-ms = <8>;
	};
};

&zip_2s_mixer {
	status = "okay";
	sync-report-ms = <0>;
	sync-scroll-report-ms = <8>;
	twist-thres = <3>;
	twist-interference-thres = <200>;
	ball-radius = <102>;
	sensor1-pos = [31 4B 2D];
	sensor2-pos = [C1 3C 2D];
};

/ {
	/* Custom scroll scaler with internal remainder tracking */
	zip_scroll_scaler_int: zip_scroll_scaler_int {
		compatible = "zmk,scroll-scaler";
		#input-processor-cells = <2>;
	};

	/* Pointer acceleration curve — dampens slow movements, passes fast ones */
	zip_pointer_accel: zip_pointer_accel {
		compatible = "zmk,accel-curve";
		#input-processor-cells = <0>;
		max-curves = <4>;
		points = <36>;
		event-codes = <INPUT_REL_X INPUT_REL_Y>;
		curve-data = <0 0 116 41 10 32 16 39
		116 41 4809 100 782 41 171 100>;
	};

	/* Scroll acceleration curve — amplifies scroll after 1/10 scaling */
	zip_scroll_accel: zip_scroll_accel {
		compatible = "zmk,accel-curve";
		#input-processor-cells = <0>;
		max-curves = <4>;
		points = <24>;
		event-codes = <INPUT_REL_WHEEL INPUT_REL_HWHEEL>;
		curve-data = <0 0 102 100 10 38 10 100
		102 100 5702 406 2271 89 544 355>;
	};

	/* Report rate limiter — throttles BLE event rate */
	zip_ble_report_rate_limit: zip_ble_report_rate_limit {
		compatible = "zmk,input-processor-report-rate-limit";
		#input-processor-cells = <0>;
		codes = <INPUT_REL_X INPUT_REL_Y INPUT_REL_WHEEL INPUT_REL_HWHEEL>;
		limit-ble-only;
	};

	/*
	 * Input-split: captures mixer output, processes fully, compresses, sends over BLE.
	 * Chain: scroll_scaler → pointer_accel → scroll_accel → rate_limit → xyz_compress
	 */
	split_inputs {
		#address-cells = <1>;
		#size-cells = <0>;
		trackball_split: trackball_split@0 {
			compatible = "zmk,input-split";
			reg = <0>;
			device = <&zip_2s_mixer>;
			input-processors =
			<&zip_scroll_scaler_int 1 10>,
			<&zip_pointer_accel>,
			<&zip_scroll_accel>,
			<&zip_ble_report_rate_limit>,
			<&zip_xyz>;
		};
	};

	/* Input-listeners for sensor → mixer bridge (compiled out on split peripheral,
	 * but the bridge code in efogtech_trackball_0.c handles this instead) */
	trackball_primary_listener: trackball_primary_listener {
		compatible = "zmk,input-listener";
		device = <&trackball_primary>;
		input-processors = <&zip_2s_mixer INPUT_MIXER_SENSOR1>;
	};

	trackball_secondary_listener: trackball_secondary_listener {
		compatible = "zmk,input-listener";
		device = <&trackball_secondary>;
		input-processors = <&zip_2s_mixer INPUT_MIXER_SENSOR2>;
	};
};

&spi0 {
	status = "okay";
	compatible = "nordic,nrf-spim";
	pinctrl-0 = <&spi0_default>;
	pinctrl-1 = <&spi0_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&gpio0 30 (GPIO_ACTIVE_LOW)>;
	clock-frequency = <4000000>;

	trackball_primary: trackball_primary@0 {
		status = "okay";
		compatible = "pixart,paw3395";
		reg = <0>;
		spi-max-frequency = <4000000>;
		irq-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		cpi = <2400>;
		evt-type = <INPUT_EV_REL>;
		x-input-code = <INPUT_REL_X>;
		y-input-code = <INPUT_REL_Y>;
		power-mode = <PAW3395_OFFICE>;
		invert-x;
		invert-y;
	};
};

&spi1 {
	status = "okay";
	compatible = "nordic,nrf-spim";
	pinctrl-0 = <&spi1_default>;
	pinctrl-1 = <&spi1_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&gpio1 7 (GPIO_ACTIVE_LOW)>;
	clock-frequency = <4000000>;

	trackball_secondary: trackball_secondary@0 {
		status = "okay";
		compatible = "pixart,paw3395";
		reg = <0>;
		spi-max-frequency = <4000000>;
		irq-gpios = <&gpio1 4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		cpi = <2400>;
		evt-type = <INPUT_EV_REL>;
		x-input-code = <INPUT_REL_X>;
		y-input-code = <INPUT_REL_Y>;
		power-mode = <PAW3395_OFFICE>;
	};
};
